            <Link href="/catalog" className="hover:text-yellow-400 transition-colors">Equipment</Link>
            <span>/</span>
            <span className="text-gray-400">{page.location}</span>
          </div>

          <div className="inline-flex items-center gap-2 bg-yellow-500/10 border border-yellow-500/20 rounded-full px-4 py-2 mb-6">
            <span className="w-2 h-2 bg-green-500 rounded-full animate-pulse" />
            <span className="text-yellow-400 text-sm font-semibold tracking-wide">AVAILABLE IN {page.location.toUpperCase()}</span>
          </div>

          <h1 className="text-4xl sm:text-5xl font-black text-white mb-4 leading-tight">{page.h1}</h1>
          <p className="text-gray-400 text-lg max-w-2xl leading-relaxed mb-8">{page.description}</p>

          <div className="flex flex-col sm:flex-row gap-4">
